---
export const prerender = true;
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RarityBadge from '../../components/RarityBadge.astro';
import { buildMeta } from '../../lib/seo';

export async function getStaticPaths() {
  const entries = await getCollection('characters');
  return entries.map(e => ({
    params: { slug: e.data.slug },
    props: { character: e.data },
  }));
}

const { character: c } = Astro.props;

// 관련 아티팩트 조회
const allArtifacts = await getCollection('artifacts');
const relatedArtifacts = allArtifacts
  .map(e => e.data)
  .filter(a => a.exclusive_character_slug === c.slug);

const elementLabel: Record<string, string> = {
  fire: '불', ice: '얼음', earth: '땅', wind: '바람', thunder: '번개',
};
const styleLabel: Record<string, string> = {
  brawler: '브롤러', destroyer: '파괴자', assassin: '암살자', support: '서포터',
};
const regionLabel: Record<string, string> = {
  ellendor: '엘렌도르', barein: '바레인', serenia: '세레니아', sura: '수라', namryeong: '남령',
};
const elementColor: Record<string, string> = {
  fire: 'var(--el-fire)', ice: 'var(--el-ice)', earth: 'var(--el-earth)',
  wind: 'var(--el-wind)', thunder: 'var(--el-thunder)',
};
const rarityLabel: Record<string, string> = {
  '5seong': '5성', '4seong': '4성', '3seong': '3성', 'unknown': '?성',
};
const rarityArtColor: Record<string, string> = {
  '5seong': 'var(--accent-gold)',
  '4seong': 'var(--accent)',
  '3seong': 'var(--fg-dim)',
  'unknown': 'var(--fg-dim)',
};

const meta = buildMeta({
  path: `/characters/${c.slug}`,
  title: `${c.name_ko} (${c.name_en}) — 몬길 스타다이브`,
  description: c.description ?? `${c.name_ko} — 몬길 스타다이브 캐릭터 정보.`,
  jsonLd: {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: c.name_ko,
    alternateName: c.name_en,
    description: c.description,
    image: c.portrait ? `https://stardive-fan-site.vercel.app${c.portrait}` : undefined,
  },
});

const allEntries = await getCollection('characters');
const sidebarItems = allEntries
  .map(e => e.data)
  .sort((a, b) => a.name_ko.localeCompare(b.name_ko, 'ko'))
  .map(ch => ({
    label: ch.name_ko,
    href: `/characters/${ch.slug}`,
  }));
---

<style>
  .char-layout {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 16px;
    align-items: start;
  }
  .char-portrait-col {}
  .char-portrait-img {
    width: 100%;
    max-height: 560px;
    object-fit: contain;
    object-position: top center;
    display: block;
    border: 1px solid var(--border);
    border-radius: 2px;
    background: var(--bg-surface);
  }
  .char-portrait-placeholder {
    width: 100%;
    height: 400px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background-image: repeating-linear-gradient(
      -45deg,
      transparent, transparent 6px,
      oklch(0.19 0.020 260 / 0.5) 6px, oklch(0.19 0.020 260 / 0.5) 7px
    );
  }
  .placeholder-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--fg-muted);
  }
  .placeholder-sub {
    font-size: 0.75rem;
    color: var(--fg-dim);
    font-family: 'Departure Mono', monospace;
  }
  .char-info-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .char-name-block {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .char-name-ko {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--fg-primary);
    margin: 0;
    line-height: 1.1;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .char-name-en {
    font-size: 0.75rem;
    color: var(--fg-dim);
    font-style: italic;
    margin: 0;
    letter-spacing: 0.01em;
  }
  .info-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
  }
  .info-table tr {
    border-bottom: 1px solid var(--border);
  }
  .info-table tr:last-child {
    border-bottom: none;
  }
  .info-table th {
    padding: 6px 10px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--fg-dim);
    background: var(--bg-raised);
    white-space: nowrap;
    width: 80px;
    text-align: left;
    border-right: 1px solid var(--border);
    vertical-align: top;
  }
  .info-table td {
    padding: 6px 10px;
    color: var(--fg-primary);
    background: var(--bg-surface);
    vertical-align: top;
  }
  .td-muted {
    color: var(--fg-dim);
    font-style: italic;
  }
  .el-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 4px;
    vertical-align: middle;
  }
  .char-description {
    font-size: 0.8125rem;
    color: var(--fg-muted);
    line-height: 1.55;
    margin: 0;
    padding: 10px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 2px;
  }
  .desc-missing {
    font-size: 0.8125rem;
    color: var(--fg-dim);
    font-style: italic;
    padding: 10px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    font-family: 'Departure Mono', monospace;
  }

  /* 관련 아티팩트 */
  .related-section {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .related-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--fg-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0;
  }
  .artifact-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .artifact-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 9px;
    border: 1px solid var(--border);
    border-radius: 2px;
    background: var(--bg-raised);
    font-size: 0.75rem;
    color: var(--fg-primary);
    text-decoration: none;
    transition: border-color 150ms;
  }
  .artifact-chip:hover {
    border-color: var(--accent);
  }

  .source-note {
    font-size: 0.6875rem;
    color: var(--fg-dim);
  }
  .source-link {
    color: var(--accent);
    text-decoration: none;
  }
  .source-link:hover { text-decoration: underline; }

  @media (max-width: 700px) {
    .char-layout {
      grid-template-columns: 1fr;
    }
    .char-portrait-img {
      max-height: 300px;
    }
  }
</style>

<BaseLayout
  meta={meta}
  sidebarTitle="캐릭터"
  sidebarItems={[
    { label: '← 도감으로', href: '/characters' },
    ...sidebarItems,
  ]}
>
  <div class="char-layout">
    <!-- 왼쪽: 풀 일러스트 또는 플레이스홀더 -->
    <div class="char-portrait-col">
      {c.full ? (
        <img
          class="char-portrait-img"
          src={c.full}
          alt={`${c.name_ko} 풀 일러스트`}
          loading="eager"
          decoding="async"
        />
      ) : (
        <div class="char-portrait-placeholder" role="img" aria-label={`${c.name_ko} 이미지 준비중`}>
          <span class="placeholder-name">{c.name_ko}</span>
          <span class="placeholder-sub">이미지 준비중</span>
        </div>
      )}
    </div>

    <!-- 오른쪽: 정보 -->
    <div class="char-info-col">
      <div class="char-name-block">
        <h1 class="char-name-ko">
          {c.name_ko}
          <RarityBadge rarity={c.rarity} />
        </h1>
        <p class="char-name-en">{c.name_en}</p>
      </div>

      <table class="info-table">
        <tbody>
          <tr>
            <th>지역</th>
            <td>{regionLabel[c.region] ?? c.region}</td>
          </tr>
          <tr>
            <th>속성</th>
            <td>
              {c.element ? (
                <>
                  <span class="el-dot" style={`background:${elementColor[c.element]}`} aria-hidden="true"></span>
                  {elementLabel[c.element]}
                </>
              ) : (
                <span class="td-muted">미확인</span>
              )}
            </td>
          </tr>
          <tr>
            <th>스타일</th>
            <td>
              {c.style ? styleLabel[c.style] : <span class="td-muted">미확인</span>}
            </td>
          </tr>
          <tr>
            <th>역할</th>
            <td>
              {c.role ? c.role : <span class="td-muted">미확인</span>}
            </td>
          </tr>
          <tr>
            <th>CV</th>
            <td>
              {(c.cv_kr || c.cv_jp) ? (
                <>
                  {c.cv_kr && <span>KR {c.cv_kr}</span>}
                  {c.cv_kr && c.cv_jp && <span style="margin:0 6px;color:var(--fg-dim)">·</span>}
                  {c.cv_jp && <span>JP {c.cv_jp}</span>}
                </>
              ) : (
                <span class="td-muted">미확인</span>
              )}
            </td>
          </tr>
        </tbody>
      </table>

      {c.description ? (
        <p class="char-description">{c.description}</p>
      ) : (
        <p class="desc-missing">설명 데이터 수집 중 — 공식 업데이트 반영 예정</p>
      )}

      {relatedArtifacts.length > 0 && (
        <div class="related-section">
          <p class="related-title">관련 아티팩트</p>
          <div class="artifact-chips">
            {relatedArtifacts.map(art => (
              <a class="artifact-chip" href="/artifacts">
                <RarityBadge rarity={art.rarity} />
                {art.name_ko}
              </a>
            ))}
          </div>
        </div>
      )}

      <p class="source-note">
        출처:{' '}
        <a href={c.source_url ?? 'https://stardive.netmarble.com/ko'} target="_blank" rel="noreferrer" class="source-link">
          공식 사이트 ↗
        </a>{' '}
        · 이미지 출처: 넷마블 「몬길: STAR DIVE」 © Netmarble. 비공식 팬 페이지.
      </p>
    </div>
  </div>
</BaseLayout>
