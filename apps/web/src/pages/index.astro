---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CouponCard from '../components/CouponCard.astro';
import CounterStripItem from '../components/CounterStripItem.astro';
import Rule from '../components/Rule.astro';
import { buildMeta } from '../lib/seo';

const allCoupons = await getCollection('coupons');
const topCoupons = allCoupons.map(e => e.data)
  .filter(c => c.status === 'active')
  .sort((a, b) => new Date(b.firstSeenAt).getTime() - new Date(a.firstSeenAt).getTime())
  .slice(0, 3);

const activeCouponCount = allCoupons.filter(e => e.data.status === 'active').length;

const tiers = await getCollection('tier');
const topTier = tiers.sort((a, b) =>
  new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
)[0];

// 추천 캐릭터 수: tiers에서 S·A 티어 합산
const tierData = topTier?.data.tiers ?? [];
const recommendedCount = tierData
  .filter(t => t.name === 'S' || t.name === 'A')
  .reduce((acc, t) => acc + t.characters.length, 0);

const meta = buildMeta({
  path: '/',
  title: '홈',
  description: '몬스터길들이기 STAR DIVE 쿠폰, 리세마라 티어, 공략을 한눈에.',
  jsonLd: {
    '@context': 'https://schema.org',
    '@type': 'VideoGame',
    name: '몬길: STAR DIVE',
    gamePlatform: ['Android', 'iOS', 'PC'],
    publisher: 'Netmarble',
    datePublished: '2026-04-15',
  },
});
---

<style>
  /* ─── 히어로 그리드 ─── */
  .hero {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: 2rem;
    padding: 3rem 0 2rem;
    align-items: start;
  }
  @media (max-width: 680px) {
    .hero {
      grid-template-columns: 1fr;
    }
  }

  .hero-headline {
    font-family: 'SUIT Variable', 'SUIT', sans-serif;
    font-size: clamp(4rem, 9vw, 7rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--fg-primary);
    margin: 0;
  }
  .hero-subheading {
    font-family: 'SUIT Variable', 'SUIT', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.01em;
    color: var(--accent);
    margin: 0.75rem 0 0;
  }
  .hero-desc {
    margin-top: 1.5rem;
    color: var(--fg-muted);
    max-inline-size: 48ch;
    font-size: 1rem;
    line-height: 1.65;
  }

  /* ─── 카운터 스트립 ─── */
  .counter-strip {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    border-left: 1px solid var(--border);
    padding-left: 2rem;
  }
  @media (max-width: 680px) {
    .counter-strip {
      flex-direction: row;
      border-left: none;
      border-top: 1px solid var(--border);
      padding-left: 0;
      padding-top: 1.5rem;
      flex-wrap: wrap;
      gap: 2rem;
    }
  }

  /* ─── 섹션 헤더 ─── */
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
  }
  .section-title {
    font-family: 'SUIT Variable', 'SUIT', sans-serif;
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--fg-primary);
    margin: 0;
  }
  .section-link {
    font-size: 0.8125rem;
    color: var(--accent-alt);
    text-decoration: none;
    transition: color 150ms;
  }
  .section-link:hover {
    color: var(--fg-primary);
  }

  /* ─── 쿠폰 그리드 ─── */
  .coupon-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  }
  @media (max-width: 480px) {
    .coupon-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ─── 티어 요약 블록 ─── */
  .tier-pullquote {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 400;
    line-height: 1.65;
    color: var(--fg-muted);
    max-inline-size: 68ch;
    padding-left: 1.25rem;
    border-left: 2px solid var(--border);
    margin: 0;
  }
</style>

<BaseLayout meta={meta}>
  <!-- 히어로 + 카운터 스트립 -->
  <section class="hero">
    <div>
      <h1 class="hero-headline">몬길: STAR DIVE</h1>
      <p class="hero-subheading">팬 정보 허브</p>
      <p class="hero-desc">
        오늘 출시된 「몬길: STAR DIVE」의 쿠폰·티어·공략을 실시간으로 정리합니다.
      </p>
    </div>

    <div class="counter-strip">
      <CounterStripItem value={activeCouponCount} label="사용 가능 쿠폰" />
      <CounterStripItem value={recommendedCount > 0 ? recommendedCount : 5} label="추천 캐릭터" />
      <CounterStripItem value="1" label="최신 티어 버전" />
    </div>
  </section>

  <Rule />

  <!-- 쿠폰 섹션 -->
  <section>
    <div class="section-header">
      <h2 class="section-title">지금 쓸 수 있는 쿠폰</h2>
      <a href="/coupons" class="section-link">전체 보기 ↗</a>
    </div>
    <div class="coupon-grid">
      {topCoupons.map(c => <CouponCard {...c} />)}
    </div>
  </section>

  <!-- 티어 섹션 -->
  {topTier && (
    <>
      <Rule />
      <section>
        <div class="section-header">
          <h2 class="section-title">리세마라 티어</h2>
          <a href="/tier" class="section-link">자세히 ↗</a>
        </div>
        <blockquote class="tier-pullquote">{topTier.data.summary}</blockquote>
      </section>
    </>
  )}
</BaseLayout>
