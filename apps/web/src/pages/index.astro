---
import BaseLayout from '../layouts/BaseLayout.astro';
import CouponMiniCard from '../components/CouponMiniCard.astro';
import CharacterChip from '../components/CharacterChip.astro';
import RarityBadge from '../components/RarityBadge.astro';
import { buildMeta } from '../lib/seo';
import { apiFetch } from '../lib/api';
import type { CharacterResponse, CouponResponse, ArtifactResponse } from '@stardive/shared';

interface TierCharacter {
  name: string;
  element: string;
  role: string;
  rarity?: string;
  slug?: string;
}
interface TierEntry {
  name: string;
  description?: string;
  characters: TierCharacter[];
}
interface TierResponse {
  id: number;
  slug: string;
  title: string;
  version: string;
  publishedAt: string;
  context: string;
  summary: string;
  tiers?: TierEntry[];
}

let allCoupons: CouponResponse[] = [];
try {
  allCoupons = await apiFetch<CouponResponse[]>('/coupons');
} catch (e) {
  console.warn('API unavailable, using empty data');
}
const activeCoupons = allCoupons
  .filter(c => c.status === 'active')
  .sort((a, b) => new Date(b.firstSeenAt).getTime() - new Date(a.firstSeenAt).getTime());
const activeCouponCount = activeCoupons.length;

let allTiers: TierResponse[] = [];
try {
  allTiers = await apiFetch<TierResponse[]>('/tiers');
} catch (e) {
  console.warn('API unavailable, using empty data');
}
const topTier = allTiers.sort((a, b) =>
  new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
)[0];
const tierData = topTier?.tiers ?? [];
const sTierChars = tierData.find(t => t.name === 'S')?.characters ?? [];

let allCharacters: CharacterResponse[] = [];
try {
  allCharacters = await apiFetch<CharacterResponse[]>('/characters');
} catch (e) {
  console.warn('API unavailable, using empty data');
}
const rarityOrder: Record<string, number> = { '5seong': 0, 'unknown': 1, '4seong': 2, '3seong': 3 };
const characters = allCharacters
  .sort((a, b) => {
    const ro = (rarityOrder[a.rarity] ?? 9) - (rarityOrder[b.rarity] ?? 9);
    if (ro !== 0) return ro;
    return a.nameKo.localeCompare(b.nameKo, 'ko');
  });
const characterCount = characters.length;

// 홈 하이라이트: 5성 6인
const featuredChars = characters.filter(c => c.rarity === '5seong' && c.portrait).slice(0, 6);

// 주목 아티팩트: 5성 3개
let allArtifacts: ArtifactResponse[] = [];
try {
  allArtifacts = await apiFetch<ArtifactResponse[]>('/artifacts');
} catch (e) {
  console.warn('API unavailable, using empty data');
}
const feat5Artifacts = allArtifacts
  .filter(a => a.rarity === '5seong')
  .slice(0, 3);

// 캐릭터 이름 맵
const charMap = Object.fromEntries(allCharacters.map(c => [c.slug, c.nameKo]));

// 날짜
const launchDate = new Date('2026-04-15');
const today = new Date('2026-04-15');
const daysSince = Math.floor((today.getTime() - launchDate.getTime()) / 86400000) + 1;

const regionLabel: Record<string, string> = {
  ellendor: '엘렌도르', barein: '바레인', serenia: '세레니아', sura: '수라', namryeong: '남령',
};

const meta = buildMeta({
  path: '/',
  title: '홈',
  description: '몬스터길들이기 STAR DIVE 쿠폰, 리세마라 티어, 캐릭터 정보를 한눈에.',
  jsonLd: {
    '@context': 'https://schema.org',
    '@type': 'VideoGame',
    name: '몬길: STAR DIVE',
    gamePlatform: ['Android', 'iOS', 'PC'],
    publisher: 'Netmarble',
    datePublished: '2026-04-15',
  },
});
---

<style>
  /* ─── 히어로 배경 레이어 ─── */
  .hero-section {
    position: relative;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    opacity: 0.12;
    filter: blur(2px);
    pointer-events: none;
    z-index: 0;
    transform: scale(1.04); /* blur 가장자리 보정 */
  }
  .hero-strip {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
  }
  .hero-left {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }
  .hero-logo {
    width: 40px;
    height: 40px;
    object-fit: contain;
    flex-shrink: 0;
  }
  .hero-title {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--fg-primary);
    margin: 0;
    line-height: 1.2;
  }
  .hero-tagline {
    font-size: 0.6875rem;
    color: var(--fg-dim);
    margin: 1px 0 0;
    line-height: 1;
  }
  .hero-counters {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
    background: oklch(0.11 0.018 260 / 0.7);
  }
  .counter-item {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 5px 10px;
    border-right: 1px solid var(--border);
    white-space: nowrap;
  }
  .counter-item:last-child { border-right: none; }
  .counter-num {
    font-family: 'Departure Mono', monospace;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }
  .counter-lbl {
    font-size: 0.6875rem;
    color: var(--fg-dim);
  }
  .hero-cta {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    border: 1px solid oklch(0.76 0.14 220 / 0.5);
    padding: 5px 12px;
    border-radius: 2px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 150ms, color 150ms;
    flex-shrink: 0;
    background: oklch(0.11 0.018 260 / 0.7);
  }
  .hero-cta:hover {
    background: oklch(0.76 0.14 220 / 0.1);
  }

  /* ─── 공통 섹션 레이아웃 ─── */
  .section {
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }
  .section-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }
  .section-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-gold);
    opacity: 0.8;
  }
  .section-more {
    font-size: 0.75rem;
    color: var(--fg-dim);
    text-decoration: none;
    transition: color 150ms;
  }
  .section-more:hover { color: var(--accent); }

  /* ─── 쿠폰 스크롤 ─── */
  .coupon-scroll {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding-bottom: 4px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }
  .coupon-scroll::-webkit-scrollbar { height: 4px; }
  .coupon-scroll::-webkit-scrollbar-track { background: transparent; }
  .coupon-scroll::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* ─── 캐릭터 하이라이트 ─── */
  .char-highlight-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
    align-items: start;
  }
  .char-highlight-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
    background: var(--bg-surface);
    text-decoration: none;
    color: inherit;
    transition: border-color 150ms, background 150ms;
  }
  .char-highlight-card:hover {
    border-color: var(--accent);
    background: var(--bg-raised);
  }
  .char-hl-portrait {
    width: 100%;
    aspect-ratio: 1/1;
    object-fit: cover;
    object-position: center 18%;
    display: block;
    background: var(--bg-raised);
  }
  .char-hl-info {
    padding: 5px 6px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-top: 1px solid var(--border);
  }
  .char-hl-name-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3px;
  }
  .char-hl-name {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--fg-primary);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .char-hl-region {
    font-size: 0.5625rem;
    color: var(--fg-dim);
    font-weight: 500;
    white-space: nowrap;
  }

  /* ─── 주목 아티팩트 ─── */
  .artifact-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .artifact-card {
    flex: 1;
    min-width: 160px;
    padding: 10px 12px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    transition: border-color 150ms;
    text-decoration: none;
    color: inherit;
  }
  .artifact-card:hover {
    border-color: var(--accent-gold);
  }
  .artifact-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--fg-primary);
    line-height: 1.3;
  }
  .artifact-exclusive {
    font-size: 0.6875rem;
    color: var(--fg-dim);
  }
  .artifact-exclusive span {
    color: var(--accent);
  }

  /* ─── 하단 2컬럼 ─── */
  .bottom-row {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 12px;
    padding: 10px 0;
  }
  .panel {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
  }
  .panel-header {
    padding: 6px 10px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--bg-raised);
  }
  .panel-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--fg-primary);
    letter-spacing: 0.01em;
    margin: 0;
  }
  .panel-link {
    font-size: 0.6875rem;
    color: var(--fg-dim);
    text-decoration: none;
    transition: color 150ms;
  }
  .panel-link:hover { color: var(--accent); }
  .panel-body {
    padding: 10px;
  }
  .char-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: flex-start;
  }

  /* S 티어 목록 */
  .s-tier-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .s-tier-item {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 8px;
    border-radius: 2px;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    transition: border-color 150ms;
    text-decoration: none;
    color: inherit;
  }
  .s-tier-item:hover { border-color: var(--accent-gold); }
  .s-tier-portrait {
    width: 32px;
    height: 32px;
    border-radius: 2px;
    object-fit: cover;
    object-position: top;
    background: var(--bg-base);
    flex-shrink: 0;
  }
  .s-tier-info {
    flex: 1;
    min-width: 0;
  }
  .s-tier-name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--fg-primary);
    line-height: 1.2;
  }
  .s-tier-meta {
    font-size: 0.625rem;
    color: var(--fg-dim);
  }
  .s-tier-badge {
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--accent-gold);
    font-family: 'Departure Mono', monospace;
  }
  .s-tier-empty {
    font-size: 0.75rem;
    color: var(--fg-dim);
    padding: 8px 0;
    text-align: center;
  }

  /* 반응형 */
  @media (max-width: 1024px) {
    .char-highlight-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 768px) {
    .hero-strip {
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .hero-counters {
      flex-wrap: wrap;
    }
    .bottom-row {
      grid-template-columns: 1fr;
    }
    .char-highlight-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 480px) {
    .counter-item {
      padding: 4px 7px;
    }
    .char-highlight-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<BaseLayout meta={meta}>
  <!-- Row 1: 히어로 (배경 이미지 레이어) -->
  <div class="hero-section">
    <img
      class="hero-bg"
      src="/assets/backgrounds/bg-01.jpg"
      alt=""
      aria-hidden="true"
      loading="eager"
      decoding="async"
    />
    <div class="hero-strip">
      <div class="hero-left">
        <img src="/assets/brand/logo.png" alt="STAR DIVE" class="hero-logo" width="40" height="40" />
        <div>
          <h1 class="hero-title">팬 정보 허브</h1>
          <p class="hero-tagline">몬길: STAR DIVE 비공식 팬사이트</p>
        </div>
      </div>

      <div class="hero-counters" role="status" aria-label="사이트 통계">
        <div class="counter-item">
          <span class="counter-num">{activeCouponCount}</span>
          <span class="counter-lbl">쿠폰</span>
        </div>
        <div class="counter-item">
          <span class="counter-num">{characterCount}</span>
          <span class="counter-lbl">캐릭터</span>
        </div>
        <div class="counter-item">
          <span class="counter-num">1</span>
          <span class="counter-lbl">티어</span>
        </div>
        <div class="counter-item">
          <span class="counter-num">{daysSince}</span>
          <span class="counter-lbl">일차</span>
        </div>
      </div>

      <a href="https://stardive.netmarble.com/ko" target="_blank" rel="noreferrer" class="hero-cta">
        게임 시작 ↗
      </a>
    </div>
  </div>

  <!-- Row 2: 쿠폰 스크롤 -->
  <div class="section">
    <div class="section-bar">
      <span class="section-label">쿠폰</span>
      <a href="/coupons" class="section-more">전체 보기 →</a>
    </div>
    <div class="coupon-scroll" role="list" aria-label="사용 가능 쿠폰">
      {activeCoupons.map(c => (
        <div role="listitem">
          <CouponMiniCard
            code={c.code}
            status={c.status as any}
            rewards={c.rewards}
            redemptionUrl={c.redemptionUrl}
          />
        </div>
      ))}
      {activeCoupons.length === 0 && (
        <p style="font-size:0.75rem;color:var(--fg-dim);padding:8px 0">현재 사용 가능한 쿠폰 없음</p>
      )}
    </div>
  </div>

  <!-- Row 3: 캐릭터 하이라이트 (5성 6인) -->
  {featuredChars.length > 0 && (
    <div class="section">
      <div class="section-bar">
        <span class="section-label">주목 캐릭터</span>
        <a href="/characters" class="section-more">도감 전체 →</a>
      </div>
      <div class="char-highlight-grid" role="list" aria-label="주목 캐릭터">
        {featuredChars.map(c => (
          <a class="char-highlight-card" href={`/characters/${c.slug}`} role="listitem">
            <img
              class="char-hl-portrait"
              src={c.portrait ?? ''}
              alt={c.nameKo}
              loading="lazy"
              decoding="async"
            />
            <div class="char-hl-info">
              <div class="char-hl-name-row">
                <span class="char-hl-name">{c.nameKo}</span>
                <RarityBadge rarity={c.rarity as any} />
              </div>
              <span class="char-hl-region">{regionLabel[c.region]}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Row 4: 주목 아티팩트 -->
  {feat5Artifacts.length > 0 && (
    <div class="section">
      <div class="section-bar">
        <span class="section-label">주목 아티팩트</span>
        <a href="/artifacts" class="section-more">전체 →</a>
      </div>
      <div class="artifact-row" role="list" aria-label="주목 아티팩트">
        {feat5Artifacts.map(a => (
          <a class="artifact-card" href="/artifacts" role="listitem">
            <RarityBadge rarity={a.rarity as any} />
            <span class="artifact-name">{a.nameKo}</span>
            {a.exclusiveCharacterSlug ? (
              <span class="artifact-exclusive">전용: <span>{charMap[a.exclusiveCharacterSlug] ?? a.exclusiveCharacterSlug}</span></span>
            ) : (
              <span class="artifact-exclusive" style="color:var(--fg-dim)">전용 캐릭터 미확인</span>
            )}
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Row 5: 캐릭터 칩 + S 티어 2컬럼 -->
  <div class="bottom-row">
    <!-- 캐릭터 전체 칩 -->
    <div class="panel">
      <div class="panel-header">
        <h2 class="panel-title">캐릭터 ({characterCount}인)</h2>
        <a href="/characters" class="panel-link">도감 →</a>
      </div>
      <div class="panel-body">
        <div class="char-row">
          {characters.filter(c => c.portrait && c.element && c.style).map(c => (
            <CharacterChip
              name={c.nameKo}
              element={c.element! as any}
              role={c.style! as any}
              rarity={c.rarity as any}
              slug={c.slug}
              portrait={c.portrait ?? undefined}
            />
          ))}
        </div>
      </div>
    </div>

    <!-- S 티어 미리보기 -->
    <div class="panel">
      <div class="panel-header">
        <h2 class="panel-title">S 티어 (리세마라)</h2>
        <a href="/tier" class="panel-link">전체 →</a>
      </div>
      <div class="panel-body">
        {sTierChars.length > 0 ? (
          <div class="s-tier-list">
            {sTierChars.map(c => (
              <a
                class="s-tier-item"
                href={c.slug ? `/characters/${c.slug}` : '/tier'}
              >
                {c.slug ? (
                  <img
                    class="s-tier-portrait"
                    src={`/assets/characters/portrait/${c.slug}.png`}
                    alt={c.name}
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="s-tier-portrait" style="display:flex;align-items:center;justify-content:center;font-size:0.5rem;color:var(--fg-dim)">?</div>
                )}
                <div class="s-tier-info">
                  <div class="s-tier-name">{c.name}</div>
                  <div class="s-tier-meta">{c.element} · {c.role}</div>
                </div>
                {c.rarity && <span class="s-tier-badge">
                  {c.rarity === '5seong' ? '5성' : c.rarity === '4seong' ? '4성' : '?'}
                </span>}
              </a>
            ))}
          </div>
        ) : (
          <p class="s-tier-empty">데이터 없음</p>
        )}
      </div>
    </div>
  </div>
</BaseLayout>
