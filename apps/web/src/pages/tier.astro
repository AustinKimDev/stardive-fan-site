---
import BaseLayout from '../layouts/BaseLayout.astro';
import TierStrip from '../components/TierStrip.astro';
import { buildMeta } from '../lib/seo';
import { formatDateIso } from '../lib/format';
import { apiFetch } from '../lib/api';

interface TierCharacter {
  name: string;
  element: string;
  role: string;
  rarity?: string;
  slug?: string;
}
interface TierEntry {
  name: string;
  description?: string;
  characters: TierCharacter[];
}
interface TierResponse {
  id: number;
  slug: string;
  title: string;
  version: string;
  publishedAt: string;
  context: string;
  summary: string;
  tiers?: TierEntry[];
  bodyMd?: string | null;
}

let d: TierResponse | null = null;
try {
  const allTiers = await apiFetch<TierResponse[]>('/tiers');
  d = allTiers.sort((a, b) =>
    new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
  )[0] ?? null;
} catch (e) {
  console.warn('API unavailable, using empty data');
}

if (!d) {
  d = {
    id: 0,
    slug: 'placeholder',
    title: '리세마라 티어 (데이터 로딩 중)',
    version: '0.0',
    publishedAt: new Date().toISOString(),
    context: 'reroll',
    summary: 'API 연결 후 데이터가 표시됩니다.',
    tiers: [],
  };
}

const meta = buildMeta({
  path: '/tier',
  title: d.title,
  description: d.summary,
  type: 'article',
  jsonLd: {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: d.title,
    datePublished: d.publishedAt,
    author: { '@type': 'Organization', name: 'stardive-fan-site' },
  },
});

const sidebarItems = [
  { label: '리세마라', href: '/tier', badge: 'v' + d.version },
  { label: '쿠폰', href: '/coupons' },
  { label: '캐릭터', href: '/characters' },
];

// 티어 컨텍스트 탭 (스텁 — PvE만 활성)
const contextTabs = [
  { label: 'PvE', value: 'pve', active: true },
  { label: '스토리', value: 'story', active: false },
  { label: '보스', value: 'boss', active: false },
];
---

<style>
  .tier-page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }
  .tier-title-block {}
  .tier-title {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--fg-primary);
    margin: 0 0 4px;
    line-height: 1.2;
  }
  .tier-summary {
    font-size: 0.75rem;
    color: var(--fg-dim);
    margin: 0;
    max-width: 60ch;
    line-height: 1.4;
  }
  .tier-version {
    font-family: 'Departure Mono', monospace;
    font-size: 0.6875rem;
    color: var(--fg-dim);
    border: 1px solid var(--border);
    padding: 2px 6px;
    border-radius: 2px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* 컨텍스트 탭 */
  .context-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 10px;
  }
  .context-tab {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 6px 14px;
    border: 1px solid transparent;
    border-bottom: none;
    border-radius: 2px 2px 0 0;
    cursor: pointer;
    color: var(--fg-dim);
    background: transparent;
    transition: color 150ms, background 150ms;
    text-decoration: none;
    letter-spacing: 0.02em;
    position: relative;
    bottom: -1px;
  }
  .context-tab--active {
    color: var(--accent);
    border-color: var(--border);
    background: var(--bg-surface);
    border-bottom-color: var(--bg-surface);
  }
  .context-tab--stub {
    color: var(--fg-dim);
    opacity: 0.5;
    cursor: default;
  }

  /* 티어 목록 */
  .tier-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 16px;
  }

  /* 서사 본문 */
  .tier-narrative {
    max-width: 68ch;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--fg-muted);
    border-top: 1px solid var(--border);
    padding-top: 12px;
  }
  .tier-narrative :global(h2) {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--fg-primary);
    margin: 12px 0 6px;
  }
  .tier-narrative :global(p) {
    margin: 0 0 8px;
  }
  .tier-narrative :global(blockquote) {
    border-left: 2px solid var(--border);
    padding-left: 10px;
    color: var(--fg-dim);
    margin: 8px 0;
    font-style: italic;
  }
  .tier-narrative :global(ul) {
    padding-left: 16px;
    margin: 6px 0;
  }
  .tier-narrative :global(li) {
    margin-bottom: 2px;
  }
  .tier-narrative :global(strong) {
    color: var(--fg-primary);
    font-weight: 700;
  }
  .tier-narrative :global(a) {
    color: var(--accent);
    text-decoration: none;
  }
  .tier-narrative :global(a:hover) {
    text-decoration: underline;
  }

  .tier-footer-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Departure Mono', monospace;
    font-size: 0.625rem;
    color: var(--fg-dim);
    border-top: 1px solid var(--border);
    padding-top: 8px;
    margin-top: 8px;
  }

  /* 배경 이미지 분위기 */
  .tier-bg-layer {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .tier-bg-layer img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.08;
  }
  .tier-content-wrapper {
    position: relative;
    z-index: 1;
  }
</style>

<BaseLayout
  meta={meta}
  dataSection="tier"
  sidebarTitle="티어"
  sidebarItems={sidebarItems}
>
  <!-- 분위기 배경 (fixed, pointer-events none) -->
  <div class="tier-bg-layer" aria-hidden="true">
    <img src="/assets/backgrounds/bg-03.jpg" alt="" loading="lazy" decoding="async" />
  </div>

  <div class="tier-content-wrapper">
  <div class="tier-page-header">
    <div class="tier-title-block">
      <h1 class="tier-title">{d.title}</h1>
      <p class="tier-summary">{d.summary}</p>
    </div>
    <span class="tier-version">v{d.version} · {formatDateIso(new Date(d.publishedAt))}</span>
  </div>

  <!-- 컨텍스트 탭 -->
  <div class="context-tabs" role="tablist">
    {contextTabs.map(tab => (
      <span
        role="tab"
        class:list={[
          'context-tab',
          tab.active && 'context-tab--active',
          !tab.active && 'context-tab--stub',
        ]}
        aria-selected={tab.active}
      >
        {tab.label}
        {!tab.active && <span style="font-size:0.55rem;margin-left:3px">(곧)</span>}
      </span>
    ))}
  </div>

  <!-- 티어 스트립 목록 -->
  {d.tiers && d.tiers.length > 0 ? (
    <section aria-label="티어 목록">
      <div class="tier-list">
        {d.tiers.map(t => (
          <TierStrip name={t.name} description={t.description} characters={t.characters as any} />
        ))}
      </div>
    </section>
  ) : null}

  <!-- 서사 -->
  {d.bodyMd && (
    <article class="tier-narrative">
      <p style="white-space:pre-wrap;font-size:0.8125rem;color:var(--fg-muted);line-height:1.55">{d.bodyMd}</p>
    </article>
  )}

  <!-- 푸터 메타 -->
  <div class="tier-footer-meta">
    <span>VERSION {d.version}</span>
    <span>·</span>
    <span>UPDATED {formatDateIso(new Date(d.publishedAt))}</span>
    <span>·</span>
    <span>{d.context.toUpperCase()}</span>
    <span>·</span>
    <span>업데이트: 2026-04-15 · 출시 당일 초안</span>
  </div>
  </div>{/* tier-content-wrapper */}
</BaseLayout>
