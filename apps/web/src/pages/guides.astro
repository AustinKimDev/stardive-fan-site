---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import GuideCategoryBadge from '../components/GuideCategoryBadge.astro';
import { buildMeta } from '../lib/seo';

const allEntries = await getCollection('guides');
const allGuides = allEntries
  .map(e => e.data)
  .sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());

const catParam = Astro.url.searchParams.get('cat') ?? 'all';
const validCats = ['all', 'reroll', 'tier', 'community', 'event', 'tip', 'map'] as const;
type CatParam = typeof validCats[number];
const activeCat: CatParam = (validCats as readonly string[]).includes(catParam)
  ? (catParam as CatParam)
  : 'all';

const filtered = activeCat === 'all'
  ? allGuides
  : allGuides.filter(g => g.category === activeCat);

const catLabels: Record<CatParam, string> = {
  all:       '전체',
  reroll:    '리세마라',
  tier:      '티어',
  event:     '이벤트',
  tip:       '팁',
  map:       '지도',
  community: '커뮤니티',
};

const sidebarItems = validCats.map(cat => ({
  label: catLabels[cat],
  href: cat === 'all' ? '/guides' : `/guides?cat=${cat}`,
}));

const meta = buildMeta({
  path: '/guides',
  title: '몬길 스타다이브 공략·커뮤니티 리소스',
  description: '리세마라·티어표·보물상자 지도 등 팬 커뮤니티 공략 모음',
  jsonLd: {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: '스타다이브 공략·커뮤니티 리소스',
    numberOfItems: allGuides.length,
    itemListElement: allGuides.map((g, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Article',
        name: g.title,
        url: g.externalUrl ?? `https://stardive.fans/guides/${g.slug}`,
        description: g.summary,
      },
    })),
  },
});

function formatDate(d: Date): string {
  return d.toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' });
}
---

<style>
  .page-header {
    margin-bottom: 12px;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }
  .page-title {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--fg-primary);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .count-badge {
    font-size: 0.75rem;
    font-weight: 700;
    font-family: 'Departure Mono', monospace;
    color: var(--accent);
    background: oklch(0.76 0.14 220 / 0.1);
    border: 1px solid oklch(0.76 0.14 220 / 0.3);
    padding: 1px 7px;
    border-radius: 2px;
  }

  /* 테이블 */
  .guides-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 2px;
    background: var(--bg-surface);
  }
  .guides-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    font-variant-numeric: tabular-nums;
    min-width: 620px;
  }
  .guides-table thead th {
    padding: 6px 10px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-dim);
    border-bottom: 1px solid var(--border-strong);
    background: var(--bg-raised);
    white-space: nowrap;
    text-align: left;
  }
  .guides-table tbody tr {
    border-bottom: 1px solid var(--border);
    transition: background 120ms;
  }
  .guides-table tbody tr:last-child {
    border-bottom: none;
  }
  .guides-table tbody tr:hover {
    background: var(--bg-raised);
  }
  .guides-table td {
    padding: 7px 10px;
    vertical-align: middle;
    color: var(--fg-primary);
  }
  .th-cat   { width: 88px; min-width: 80px; }
  .th-date  { width: 80px; min-width: 72px; }

  .td-title-wrap {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .guide-link {
    color: var(--fg-primary);
    text-decoration: none;
    font-weight: 600;
    transition: color 150ms;
  }
  .guide-link:hover {
    color: var(--accent);
  }
  .guide-summary {
    font-size: 0.75rem;
    color: var(--fg-dim);
    line-height: 1.4;
    margin: 0;
  }
  .source-label {
    font-size: 0.75rem;
    color: var(--fg-dim);
  }
  .date-text {
    font-size: 0.75rem;
    color: var(--fg-dim);
    white-space: nowrap;
  }
  .empty-row td {
    padding: 24px 10px;
    text-align: center;
    color: var(--fg-dim);
    font-size: 0.8125rem;
  }
</style>

<BaseLayout
  meta={meta}
  sidebarTitle="공략"
  sidebarItems={sidebarItems}
  fullWidth={false}
>
  <div class="page-header">
    <h1 class="page-title">
      공략·커뮤니티 리소스
      <span class="count-badge">{filtered.length}개</span>
    </h1>
  </div>

  <div class="guides-table-wrap">
    <table class="guides-table" aria-label="공략 리소스 목록">
      <thead>
        <tr>
          <th class="th-cat">카테고리</th>
          <th>제목 / 요약</th>
          <th>출처</th>
          <th class="th-date">발행일</th>
        </tr>
      </thead>
      <tbody>
        {filtered.length === 0 ? (
          <tr class="empty-row">
            <td colspan="4">해당 카테고리 공략이 없습니다.</td>
          </tr>
        ) : (
          filtered.map(g => (
            <tr>
              <td><GuideCategoryBadge category={g.category} /></td>
              <td>
                <div class="td-title-wrap">
                  {g.externalUrl ? (
                    <a
                      href={g.externalUrl}
                      class="guide-link"
                      target="_blank"
                      rel="noreferrer"
                    >
                      {g.title} ↗
                    </a>
                  ) : (
                    <a href={`/guides/${g.slug}`} class="guide-link">
                      {g.title}
                    </a>
                  )}
                  <p class="guide-summary">{g.summary}</p>
                </div>
              </td>
              <td>
                <span class="source-label">{g.sourceLabel ?? '—'}</span>
              </td>
              <td>
                <span class="date-text">{formatDate(g.publishedAt)}</span>
              </td>
            </tr>
          ))
        )}
      </tbody>
    </table>
  </div>
</BaseLayout>

<style is:inline>
  .guides-inner {
    max-width: 1100px;
    margin: 0 auto;
  }
</style>
