---
interface Props {
  value: string | number;
  label: string;
}
const { value, label } = Astro.props;
---

<style>
  .counter-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .counter-number {
    font-family: 'Departure Mono', 'Courier New', monospace;
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 400;
    line-height: 1;
    color: var(--fg-primary);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }
  .counter-label {
    font-family: 'SUIT Variable', 'SUIT', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }
</style>

<div class="counter-item">
  <span class="counter-number">{value}</span>
  <span class="counter-label">{label}</span>
</div>
