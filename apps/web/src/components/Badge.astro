---
type Variant = 'active' | 'expired' | 'unknown' | 'limited' | 'permanent' | 'urgent' | 'scheduled';
interface Props { variant: Variant }
const { variant } = Astro.props;

const styles: Record<Variant, string> = {
  /* active — ice cyan */
  active:
    'background:oklch(0.76 0.14 220 / 0.12);color:var(--accent);border:1px solid oklch(0.76 0.14 220 / 0.4)',
  /* expired — hot orange */
  expired:
    'background:oklch(0.72 0.18 40 / 0.1);color:var(--accent-hot);border:1px solid oklch(0.72 0.18 40 / 0.3)',
  /* unknown — dim dashed */
  unknown:
    'background:transparent;color:var(--fg-dim);border:1px dashed var(--border)',
  limited:
    'background:oklch(0.82 0.13 85 / 0.1);color:var(--accent-gold);border:1px solid oklch(0.82 0.13 85 / 0.35)',
  permanent:
    'background:oklch(0.76 0.14 220 / 0.08);color:var(--accent);border:1px solid oklch(0.76 0.14 220 / 0.25)',
  urgent:
    'background:oklch(0.72 0.18 40 / 0.12);color:var(--accent-hot);border:1px solid oklch(0.72 0.18 40 / 0.4)',
  scheduled:
    'background:transparent;color:var(--fg-dim);border:1px solid var(--border)',
};
---
<span style={`display:inline-flex;align-items:center;gap:0.25rem;padding:1px 5px;border-radius:2px;font-size:0.625rem;font-weight:700;letter-spacing:0.04em;line-height:1.2;${styles[variant]}`}>
  <slot />
</span>
