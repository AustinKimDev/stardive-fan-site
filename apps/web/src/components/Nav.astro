---
const groups = [
  { label: '도감', href: '/characters', placeholder: true },
  { label: '공략', href: '/tier', placeholder: false },
  { label: '소식', href: '/coupons', placeholder: false },
  { label: '세계관', href: '/lore', placeholder: true },
];
const pathname = Astro.url.pathname;
---
<nav style="position:sticky;top:0;z-index:40;backdrop-filter:blur(8px);background:oklch(0.14 0.045 268 / 0.85);border-bottom:1px solid var(--border)">
  <div style="max-width:80rem;margin:0 auto;display:flex;align-items:center;gap:1.5rem;padding:0 1rem;height:3.5rem">
    <a href="/" style="font-weight:800;letter-spacing:-0.02em;color:var(--fg-primary);text-decoration:none;font-size:1rem">
      스타다이브
    </a>
    <ul style="display:flex;gap:1rem;list-style:none;margin:0;padding:0;font-size:0.875rem">
      {groups.map(g => (
        <li>
          <a
            href={g.href}
            aria-current={pathname === g.href || pathname.startsWith(g.href + '/') ? 'page' : undefined}
            style={[
              'padding:0.25rem 0.5rem;border-radius:0.375rem;text-decoration:none;transition:background 200ms',
              pathname === g.href || pathname.startsWith(g.href + '/') ? 'background:oklch(0.87 0.055 290 / 0.15);color:var(--accent-alt)' : '',
              g.placeholder ? 'color:var(--fg-dim)' : 'color:var(--fg-muted)',
            ].filter(Boolean).join(';')}
          >{g.label}{g.placeholder ? ' (곧)' : ''}</a>
        </li>
      ))}
    </ul>
  </div>
</nav>
