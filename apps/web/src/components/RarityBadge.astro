---
type Rarity = '5seong' | '4seong' | '3seong' | 'unknown';

interface Props {
  rarity: Rarity;
}

const { rarity } = Astro.props;

const label: Record<Rarity, string> = {
  '5seong':  '5성',
  '4seong':  '4성',
  '3seong':  '3성',
  'unknown': '?성',
};

const styles: Record<Rarity, string> = {
  '5seong':  'background:oklch(0.82 0.13 85 / 0.15);color:var(--accent-gold);border:1px solid oklch(0.82 0.13 85 / 0.5)',
  '4seong':  'background:oklch(0.76 0.14 220 / 0.12);color:var(--accent);border:1px solid oklch(0.76 0.14 220 / 0.4)',
  '3seong':  'background:transparent;color:var(--fg-dim);border:1px solid var(--border)',
  'unknown': 'background:transparent;color:var(--fg-dim);border:1px solid var(--border)',
};
---

<span style={`display:inline-flex;align-items:center;padding:1px 5px;border-radius:2px;font-size:0.6875rem;font-weight:700;letter-spacing:0.04em;line-height:1.2;${styles[rarity]}`}>
  {label[rarity]}
</span>
