---
type Element = 'fire' | 'ice' | 'earth' | 'wind' | 'thunder';
type Role = 'brawler' | 'destroyer' | 'assassin' | 'support';
type Rarity = '5seong' | '4seong' | '3seong' | 'unknown';

interface Props {
  name: string;
  element: Element;
  role: Role;
  rarity?: Rarity;
  slug?: string;
  portrait?: string;
}
const { name, element, role, rarity, slug, portrait } = Astro.props;

const elementColor: Record<Element, string> = {
  fire:    'var(--el-fire)',
  ice:     'var(--el-ice)',
  earth:   'var(--el-earth)',
  wind:    'var(--el-wind)',
  thunder: 'var(--el-thunder)',
};

const elementLabel: Record<Element, string> = {
  fire: '불', ice: '얼음', earth: '땅', wind: '바람', thunder: '번개',
};

const rarityLabel: Record<Rarity, string> = {
  '5seong': '5성',
  '4seong': '4성',
  '3seong': '3성',
  'unknown': '?',
};

const rarityColor: Record<Rarity, string> = {
  '5seong': 'var(--accent-gold)',
  '4seong': 'var(--accent)',
  '3seong': 'var(--fg-dim)',
  'unknown': 'var(--fg-dim)',
};

const portraitSrc = portrait ?? (slug ? `/assets/characters/portrait/${slug}.png` : null);
const color = elementColor[element];
---

<style>
  .chip-portrait {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    width: 56px;
    text-decoration: none;
    color: inherit;
  }
  .chip-img-wrap {
    position: relative;
    width: 48px;
    height: 48px;
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
    background: var(--bg-raised);
    transition: border-color 150ms;
  }
  .chip-portrait:hover .chip-img-wrap {
    border-color: var(--accent);
  }
  .chip-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }
  .chip-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.5rem;
    color: var(--fg-dim);
    font-family: 'Departure Mono', monospace;
    background-image: repeating-linear-gradient(
      -45deg,
      transparent, transparent 3px,
      oklch(0.19 0.020 260 / 0.5) 3px, oklch(0.19 0.020 260 / 0.5) 4px
    );
  }
  .chip-el-dot {
    position: absolute;
    top: 2px;
    right: 2px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
  }
  .chip-rarity {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    font-size: 0.5625rem;
    font-weight: 700;
    text-align: center;
    letter-spacing: 0.04em;
    padding: 1px 0;
    background: oklch(0.08 0.010 260 / 0.85);
    line-height: 1;
  }
  .chip-name {
    font-size: 0.6875rem;
    color: var(--fg-muted);
    text-align: center;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  /* 텍스트 전용 칩 (초상화 없을 때) */
  .chip-text {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 8px;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 2px;
    font-size: 0.8125rem;
    color: var(--fg-primary);
    line-height: 1;
    text-decoration: none;
    transition: border-color 150ms;
  }
  .chip-text:hover {
    border-color: var(--border-strong);
  }
  .chip-text-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .chip-text-name { font-weight: 600; }
  .chip-text-meta { color: var(--fg-dim); font-size: 0.6875rem; }
  .chip-text-rarity { font-size: 0.6875rem; font-weight: 700; }
</style>

{portraitSrc ? (
  <a class="chip-portrait" href={slug ? `/characters/${slug}` : undefined} title={`${name} — ${elementLabel[element]}`}>
    <div class="chip-img-wrap">
      <img class="chip-img" src={portraitSrc} alt={name} loading="lazy" decoding="async" />
      <span class="chip-el-dot" style={`background:${color}`} aria-hidden="true"></span>
      {rarity && rarity !== '3seong' && (
        <span class="chip-rarity" style={`color:${rarityColor[rarity]}`}>
          {rarityLabel[rarity]}
        </span>
      )}
    </div>
    <span class="chip-name">{name}</span>
  </a>
) : (
  <div class="chip-text">
    <span class="chip-text-dot" style={`background:${color}`} aria-hidden="true"></span>
    <span class="chip-text-name">{name}</span>
    <span class="chip-text-meta">{elementLabel[element]}</span>
    {rarity && <span class="chip-text-rarity" style={`color:${rarityColor[rarity]}`}>{rarityLabel[rarity]}</span>}
  </div>
)}
