---
type Element = 'fire' | 'ice' | 'earth' | 'wind' | 'thunder';
type Role = 'brawler' | 'destroyer' | 'assassin' | 'support';

interface Props {
  name: string;
  element: Element;
  role: Role;
  rarity?: 'SSR' | 'SR' | 'R';
}
const { name, element, role, rarity } = Astro.props;

const elementLabel: Record<Element, string> = {
  fire: '불',
  ice: '얼음',
  earth: '땅',
  wind: '바람',
  thunder: '번개',
};

const elementColor: Record<Element, string> = {
  fire:    'oklch(0.68 0.18 25)',
  ice:     'oklch(0.75 0.10 220)',
  earth:   'oklch(0.70 0.12 110)',
  wind:    'oklch(0.72 0.14 145)',
  thunder: 'oklch(0.80 0.14 80)',
};

const roleLabel: Record<Role, string> = {
  brawler:   '브롤러',
  destroyer: '파괴',
  assassin:  '암살',
  support:   '지원',
};
---

<style>
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.625rem;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 0.8125rem;
    color: var(--fg-primary);
    line-height: 1;
  }
  .chip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .chip-name {
    font-weight: 600;
  }
  .chip-meta {
    color: var(--fg-dim);
    font-size: 0.6875rem;
  }
  .chip-rarity {
    color: var(--accent);
    font-size: 0.6875rem;
    font-weight: 700;
  }
</style>

<div class="chip">
  <span class="chip-dot" style={`background:${elementColor[element]}`} aria-hidden="true"></span>
  <span class="chip-name">{name}</span>
  <span class="chip-meta">{elementLabel[element]} · {roleLabel[role]}</span>
  {rarity && <span class="chip-rarity">{rarity}</span>}
</div>
