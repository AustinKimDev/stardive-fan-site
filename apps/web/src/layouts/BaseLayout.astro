---
import '../styles/global.css';
import TopBar from '../components/TopBar.astro';
import Sidebar from '../components/Sidebar.astro';
import type { PageMeta } from '../lib/seo';

interface SidebarItem {
  label: string;
  href: string;
  badge?: string;
}

interface Props {
  meta: PageMeta;
  dataSection?: string;
  sidebarTitle?: string;
  sidebarItems?: SidebarItem[];
  fullWidth?: boolean;
}
const { meta, dataSection, sidebarTitle, sidebarItems, fullWidth = false } = Astro.props;
const hasSidebar = sidebarItems && sidebarItems.length > 0;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <link rel="canonical" href={meta.canonical} />
    {meta.noindex && <meta name="robots" content="noindex" />}
    <meta property="og:type" content={meta.type} />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={meta.canonical} />
    <meta property="og:image" content={meta.ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    {meta.jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(meta.jsonLd)} />}
  </head>
  <body data-section={dataSection}>
    <TopBar />

    <div class:list={['page-wrapper', fullWidth && 'page-wrapper--full']}>
      {hasSidebar ? (
        <div class="wiki-layout">
          <Sidebar title={sidebarTitle} items={sidebarItems} />
          <main class="wiki-content">
            <slot />
          </main>
        </div>
      ) : (
        <main class="page-main">
          <slot />
        </main>
      )}
    </div>

    <footer class="site-footer">
      <div class="footer-inner">
        <span>© 2026 stardive-fan-site — 비공식 팬사이트.</span>
        <span>이미지 출처: 넷마블 「몬길: STAR DIVE」 공식 사이트 (stardive.netmarble.com, guide.netmarble.com). © Netmarble.</span>
        <img src="/assets/brand/guide-badge.png" alt="확률안내" height="20" style="vertical-align:middle;opacity:0.6" loading="lazy" />
      </div>
    </footer>
  </body>
</html>

<style>
  .page-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 12px;
  }
  .page-wrapper--full {
    max-width: 100%;
  }
  .wiki-layout {
    display: flex;
    gap: 12px;
    padding: 12px 0;
    align-items: flex-start;
  }
  .wiki-content {
    flex: 1;
    min-width: 0;
    max-width: 880px;
  }
  .page-main {
    padding: 12px 0;
    max-width: 880px;
  }
  .page-wrapper--full .page-main {
    max-width: none;
  }
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 24px;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    font-size: 0.6875rem;
    color: var(--fg-dim);
  }
  /* 모바일: 사이드바가 상단 탭 스트립 */
  @media (max-width: 1023px) {
    .wiki-layout {
      flex-direction: column;
      gap: 8px;
    }
    .wiki-content {
      max-width: 100%;
      width: 100%;
    }
  }
</style>
